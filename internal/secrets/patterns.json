{
  "patterns": [
    {
      "name": "anthropic",
      "regex": "sk-ant-[A-Za-z0-9_-]{20,}",
      "description": "Anthropic API keys"
    },
    {
      "name": "openai",
      "regex": "\\bsk-[A-Za-z0-9]{20,}\\b",
      "description": "OpenAI API keys"
    },
    {
      "name": "aws-access-key",
      "regex": "\\bAKIA[0-9A-Z]{16}\\b",
      "description": "AWS access key IDs"
    },
    {
      "name": "google-api",
      "regex": "\\bAIza[A-Za-z0-9_-]{35}\\b",
      "description": "Google API keys"
    },
    {
      "name": "github-pat",
      "regex": "\\bghp_[A-Za-z0-9]{30,}\\b",
      "description": "GitHub classic personal access tokens"
    },
    {
      "name": "github-fine",
      "regex": "\\bgithub_pat_[A-Za-z0-9_]{30,}\\b",
      "description": "GitHub fine-grained personal access tokens"
    },
    {
      "name": "jwt",
      "regex": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b",
      "description": "JSON Web Tokens"
    },
    {
      "name": "slack",
      "regex": "\\bxox[baprs]-[A-Za-z0-9-]{10,}\\b",
      "description": "Slack API tokens"
    },
    {
      "name": "pem",
      "regex": "-----BEGIN (?:RSA |EC |DSA |OPENSSH |ENCRYPTED |PGP )?PRIVATE KEY-----",
      "description": "PEM-encoded private keys"
    }
  ]
}
